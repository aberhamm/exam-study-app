# =============================================================================
# Data Pipelines - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# =============================================================================
# SUPABASE (Required for enrich-questions pipeline)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# =============================================================================
# AI SERVICES
# =============================================================================

# --- OpenAI (always used for embeddings) ---
OPENAI_API_KEY=your-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# --- OpenRouter (for chat completions when PIPELINES_USE_PORTKEY=false) ---
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# --- Portkey (for chat completions when PIPELINES_USE_PORTKEY=true) ---
# OPENROUTER_API_KEY is not required when PIPELINES_USE_PORTKEY=true
# Embeddings always use OpenAI directly regardless of this flag.
PIPELINES_USE_PORTKEY=false
PORTKEY_API_KEY=your-portkey-api-key
PORTKEY_BASE_URL=https://api.portkey.ai/v1
PORTKEY_PROVIDER=
# Use PORTKEY_MODEL_QUESTION_GENERATION for pipeline-specific model; falls back to PORTKEY_MODEL
PORTKEY_MODEL=anthropic/claude-3.5-sonnet
PORTKEY_MODEL_QUESTION_GENERATION=
# Custom headers (key:value pairs separated by literal \n)
PORTKEY_CUSTOM_HEADERS=

# =============================================================================
# PIPELINE CONFIGURATION (Optional)
# =============================================================================
API_TIMEOUT_MS=30000
MAX_RETRIES=3
MAX_CANDIDATES=100
CANDIDATE_MULTIPLIER=10
DEBUG_RETRIEVAL=false
